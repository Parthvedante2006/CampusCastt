<?xml version="1.0" encoding="utf-8"?>
<!--
    Development network security config.
    Allows plain HTTP to any host — needed for local server + HLS streaming.
    For production: switch to HTTPS + ngrok and remove this file.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
